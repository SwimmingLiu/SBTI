{
  "name": "sbti",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "package:out": "rm -rf out dist && next build && mkdir -p dist && cd out && zip -qr ../dist/sbti-static-out.zip .",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "sync:herti-data": "tsx scripts/generate-herti-data.ts",
    "sync:sdti-data": "tsx scripts/generate-sdti-data.ts",
    "capture:remote": "tsx scripts/capture-remote-results.ts",
    "capture:local": "tsx scripts/capture-local-results.ts",
    "capture:sdti": "tsx scripts/capture-sdti-results.ts",
    "capture:herti": "tsx scripts/capture-herti-results.ts"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vercel": "^48.1.6",
    "vitest": "^4.1.4"
  }
}
